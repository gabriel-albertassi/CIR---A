generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  ADMINISTRATIVO
  ENFERMEIRO_AUDITOR
  REGULADOR
}

model User {
  id               String   @id // Supabase Auth UID
  name             String
  email            String   @unique
  role             UserRole @default(REGULADOR)
  canCancelPatient Boolean  @default(false)
  canPrintReports  Boolean  @default(false)
  createdAt        DateTime @default(now())
  logs             Log[]
}

model Patient {
  id               String   @id @default(uuid())
  name             String
  origin_hospital  String
  diagnosis        String
  severity         String   // LOW, MEDIUM, HIGH, CRITICAL
  status           String   @default("WAITING") // WAITING, OFFERED, TRANSFERRED, CANCELLED
  created_at       DateTime @default(now())
  attempts_count   Int      @default(0)
  last_offer_date  DateTime?
  observations     String?
  transfer_date    DateTime?
  outcome_date     DateTime?
  attachment_url   String?
  attachment_name  String?
  evolution_url    String?
  evolution_name   String?
  is_private       Boolean  @default(false)
  cns              String?
  logs             Log[]
  notifications    Notification[]
}

model Log {
  id         String   @id @default(uuid())
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  patient_id String
  user       User?    @relation(fields: [user_id], references: [id])
  user_id    String?
  action     String   // REGISTER, OFFER, TRANSFER, CANCEL, STATUS_UPDATE
  details    String?
  timestamp  DateTime @default(now())
}

model BedAvailability {
  id             String   @id @default(uuid())
  hospital_name  String   @unique
  cti_masc       Int      @default(0)
  cti_fem        Int      @default(0)
  clinica_masc   Int      @default(0)
  clinica_fem    Int      @default(0)
  sem_vagas      Boolean  @default(false)
  updated_at     DateTime @updatedAt
}
model Hospital {
  id             String   @id @default(uuid())
  name           String   @unique
  email          String?
  whatsapp       String?
  type           String   @default("PUBLICO") // PUBLICO, PRIVADO/CONTRATADO
  accepts_cti    Boolean  @default(false)
  accepts_clinica Boolean @default(true)
  notifications  Notification[]
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String   @default("INFO") // INFO, SUCCESS, WARNING, ALERT
  
  hospital    Hospital? @relation(fields: [hospital_id], references: [id])
  hospital_id String?
  
  patient     Patient? @relation(fields: [patient_id], references: [id])
  patient_id  String?
  
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
}
model CirilaAudit {
  id              String   @id @default(uuid())
  exam_type       String   // TC, RNM, ECO, etc
  patient_name    String
  hospital_origin String
  destination     String
  professional    String
  key             String   @unique
  timestamp       DateTime @default(now())

  @@index([exam_type])
  @@index([timestamp])
}

model AuthorizationKey {
  id              String   @id @default(uuid())
  created_at      DateTime @default(now())
  date            DateTime @default(now())
  key             String   
  patient         String
  exam            String
  procedure       String?
  origin          String
  destination     String
  professional    String
  user_created    String?  // ID do usuário que gerou
  type            String   // TC, RNM, etc
  status          String   @default("ATIVO") // ATIVO, CANCELADO
  month           Int
  year            Int
  cns             String?

  @@map("authorization_keys")
  @@index([month, year])
  @@index([type])
  @@index([origin])
}

